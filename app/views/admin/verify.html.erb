<%# Admin verification — 6-digit confirmation code sent to ADMIN_EMAIL %>

<div class="min-h-screen bg-[#F8FAFC] flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <%# Logo %>
    <div class="text-center mb-8">
      <h2 class="text-2xl font-black text-[#0F766E] tracking-tight font-['Plus_Jakarta_Sans']">Trato</h2>
      <p class="text-sm text-slate-500 mt-1">Panel de Administración</p>
    </div>

    <%# Verification card %>
    <div class="bg-white rounded-2xl shadow-[0_32px_64px_-15px_rgba(17,28,45,0.08)] p-8">
      <h1 class="text-xl font-extrabold text-[#111C2D] mb-2 font-['Plus_Jakarta_Sans']">Código de confirmación</h1>
      <p class="text-sm text-slate-500 mb-6">
        Enviamos un código de 6 dígitos al contacto del administrador. Ingrésalo para continuar.
      </p>

      <% if flash[:alert] %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: admin_verify_path, method: :post, local: true, class: "space-y-4" do |f| %>
        <div>
          <label for="code" class="block text-sm font-semibold text-[#111C2D] mb-1.5">Código de verificación</label>
          <input type="text" name="code" id="code" required autocomplete="one-time-code"
                 inputmode="numeric" pattern="[0-9]*" maxlength="6"
                 class="w-full px-4 py-3 bg-[#F0F3FF] border-none rounded-xl text-sm text-center tracking-[0.5em] font-mono text-lg focus:ring-2 focus:ring-[#0F766E]/20 focus:bg-white transition-all placeholder:text-slate-400 placeholder:tracking-normal"
                 placeholder="000000">
        </div>

        <button type="submit"
                class="w-full bg-[#0F766E] hover:bg-[#0D6B64] text-white py-3 rounded-xl font-bold text-sm transition-all hover:scale-[0.99]">
          Verificar →
        </button>
      <% end %>

      <div class="mt-4 text-center">
        <%= link_to "← Volver al inicio de sesión", admin_login_path, class: "text-sm text-slate-500 hover:text-[#0F766E] transition-colors" %>
      </div>
    </div>

    <p class="text-center text-xs text-slate-400 mt-6">
      El código expira en 10 minutos.
    </p>
  </div>
</div>
