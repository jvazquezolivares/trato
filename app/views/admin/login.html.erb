<%# Admin login — username + password form %>
<%# Centered card on light gray background, matching Stitch design pattern %>

<div class="min-h-screen bg-[#F8FAFC] flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <%# Logo %>
    <div class="text-center mb-8">
      <h2 class="text-2xl font-black text-[#0F766E] tracking-tight font-['Plus_Jakarta_Sans']">Trato</h2>
      <p class="text-sm text-slate-500 mt-1">Panel de Administración</p>
    </div>

    <%# Login card %>
    <div class="bg-white rounded-2xl shadow-[0_32px_64px_-15px_rgba(17,28,45,0.08)] p-8">
      <h1 class="text-xl font-extrabold text-[#111C2D] mb-2 font-['Plus_Jakarta_Sans']">Acceso administrativo</h1>
      <p class="text-sm text-slate-500 mb-6">Ingresa tus credenciales. Te enviaremos un código de confirmación.</p>

      <% if flash[:alert] %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: admin_login_path, method: :post, local: true, class: "space-y-4" do |f| %>
        <div>
          <label for="username" class="block text-sm font-semibold text-[#111C2D] mb-1.5">Usuario</label>
          <input type="text" name="username" id="username" required autocomplete="username"
                 class="w-full px-4 py-3 bg-[#F0F3FF] border-none rounded-xl text-sm focus:ring-2 focus:ring-[#0F766E]/20 focus:bg-white transition-all placeholder:text-slate-400"
                 placeholder="Nombre de usuario">
        </div>

        <div>
          <label for="password" class="block text-sm font-semibold text-[#111C2D] mb-1.5">Contraseña</label>
          <input type="password" name="password" id="password" required autocomplete="current-password"
                 class="w-full px-4 py-3 bg-[#F0F3FF] border-none rounded-xl text-sm focus:ring-2 focus:ring-[#0F766E]/20 focus:bg-white transition-all placeholder:text-slate-400"
                 placeholder="••••••••">
        </div>

        <button type="submit"
                class="w-full bg-[#0F766E] hover:bg-[#0D6B64] text-white py-3 rounded-xl font-bold text-sm transition-all hover:scale-[0.99]">
          Iniciar sesión →
        </button>
      <% end %>
    </div>

    <p class="text-center text-xs text-slate-400 mt-6">
      Acceso restringido a administradores autorizados.
    </p>
  </div>
</div>
