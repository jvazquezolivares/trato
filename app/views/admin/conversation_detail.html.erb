<%# Admin Conversation Detail — full message history with chat bubbles %>
<% content_for(:page_title, "Conversación") %>

<div class="mb-4">
  <%= link_to admin_conversations_path, class: "text-sm text-slate-500 hover:text-[#0F766E] transition-colors flex items-center gap-1" do %>
    <span class="material-symbols-outlined text-sm">arrow_back</span> Volver a conversaciones
  <% end %>
</div>

<%# Conversation header %>
<div class="bg-white rounded-xl p-4 lg:p-6 shadow-[0_32px_64px_-15px_rgba(17,28,45,0.06)] mb-6">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h2 class="text-lg font-extrabold text-[#111C2D] font-['Plus_Jakarta_Sans']">
        <%= @provider&.name %> ↔ <%= mask_phone(@conversation.phone) %>
      </h2>
      <p class="text-sm text-slate-500">
        Rol: <span class="font-medium"><%= @conversation.role&.capitalize %></span>
        <% if @client %>
          · Cliente: <span class="font-medium"><%= @client.name || mask_phone(@client.phone) %></span>
        <% end %>
      </p>
    </div>
    <div class="flex items-center gap-3">
      <%= stage_badge(@conversation.stage) %>
      <span class="text-xs text-slate-400">Última actividad: <%= time_ago_spanish(@conversation.last_message_at) %></span>
    </div>
  </div>
</div>

<%# Message history — chat bubbles %>
<div class="bg-white rounded-xl p-4 lg:p-6 shadow-[0_32px_64px_-15px_rgba(17,28,45,0.06)]">
  <% if @messages.any? %>
    <div class="space-y-4 max-h-[600px] overflow-y-auto">
      <% last_date = nil %>
      <% @messages.each do |message| %>
        <%# Date separator %>
        <% msg_date = message.created_at&.to_date %>
        <% if msg_date != last_date %>
          <div class="text-center py-2">
            <span class="text-xs text-slate-400 bg-slate-100 px-3 py-1 rounded-full">
              <%= msg_date&.strftime("%d %b %Y") %>
            </span>
          </div>
          <% last_date = msg_date %>
        <% end %>

        <% if message.direction == "inbound" %>
          <%# Inbound — left side, light gray bubble %>
          <div class="flex justify-start">
            <div class="max-w-[80%] lg:max-w-[60%]">
              <div class="bg-[#F0F3FF] rounded-2xl rounded-bl-md px-4 py-3">
                <p class="text-sm text-[#111C2D] whitespace-pre-wrap"><%= message.body %></p>
              </div>
              <div class="flex items-center gap-2 mt-1 px-1">
                <span class="text-[10px] text-slate-400"><%= message.created_at&.strftime("%H:%M") %></span>
                <% if message.intent.present? %>
                  <span class="text-[10px] text-[#0F766E] bg-[#0F766E]/10 px-1.5 py-0.5 rounded font-medium"><%= message.intent %></span>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <%# Outbound — right side, teal bubble %>
          <div class="flex justify-end">
            <div class="max-w-[80%] lg:max-w-[60%]">
              <div class="bg-[#0F766E] rounded-2xl rounded-br-md px-4 py-3">
                <p class="text-sm text-white whitespace-pre-wrap"><%= message.body %></p>
              </div>
              <div class="flex items-center justify-end gap-2 mt-1 px-1">
                <% if message.intent.present? %>
                  <span class="text-[10px] text-[#0F766E] bg-[#0F766E]/10 px-1.5 py-0.5 rounded font-medium"><%= message.intent %></span>
                <% end %>
                <span class="text-[10px] text-slate-400"><%= message.created_at&.strftime("%H:%M") %></span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <span class="material-symbols-outlined text-4xl text-slate-300 mb-2">chat_bubble_outline</span>
      <p class="text-sm text-slate-400">Sin mensajes en esta conversación</p>
    </div>
  <% end %>
</div>
