<%# Admin Providers List — search, filters, table %>
<% content_for(:page_title, "Proveedores") %>

<%# Search and filters %>
<div class="bg-white rounded-xl p-4 lg:p-6 shadow-[0_32px_64px_-15px_rgba(17,28,45,0.06)] mb-6">
  <%= form_with url: admin_providers_path, method: :get, local: true, class: "flex flex-col lg:flex-row gap-3 lg:gap-4" do %>
    <div class="relative flex-1">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">search</span>
      <input type="text" name="search" value="<%= params[:search] %>"
             class="w-full pl-10 pr-4 py-2.5 bg-[#F0F3FF] border-none rounded-xl text-sm focus:ring-2 focus:ring-[#0F766E]/20 placeholder:text-slate-400"
             placeholder="Buscar proveedor por nombre, teléfono o UUID...">
    </div>

    <div class="flex flex-wrap gap-2 lg:gap-3">
      <%# Status filter %>
      <select name="status"
              class="px-3 py-2.5 bg-[#F0F3FF] border-none rounded-xl text-sm focus:ring-2 focus:ring-[#0F766E]/20">
        <option value="">Todos</option>
        <option value="active" <%= "selected" if params[:status] == "active" %>>Activos</option>
        <option value="inactive" <%= "selected" if params[:status] == "inactive" %>>Inactivos</option>
      </select>

      <%# City filter %>
      <select name="city"
              class="px-3 py-2.5 bg-[#F0F3FF] border-none rounded-xl text-sm focus:ring-2 focus:ring-[#0F766E]/20">
        <option value="">Todas las ciudades</option>
        <% @cities.each do |city| %>
          <option value="<%= city %>" <%= "selected" if params[:city] == city %>><%= city %></option>
        <% end %>
      </select>

      <button type="submit"
              class="px-4 py-2.5 bg-[#0F766E] text-white rounded-xl text-sm font-semibold hover:bg-[#0D6B64] transition-all">
        Filtrar
      </button>
    </div>
  <% end %>
</div>

<%# Providers table %>
<div class="bg-white rounded-xl shadow-[0_32px_64px_-15px_rgba(17,28,45,0.06)] overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-slate-100">
          <th class="text-left px-4 lg:px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Proveedor</th>
          <th class="text-left px-4 lg:px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider hidden md:table-cell">Ciudad</th>
          <th class="text-left px-4 lg:px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Estado</th>
          <th class="text-left px-4 lg:px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider hidden lg:table-cell">Registro</th>
          <th class="text-left px-4 lg:px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider hidden lg:table-cell">Calificación</th>
          <th class="text-right px-4 lg:px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Acciones</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        <% @providers.each do |provider| %>
          <% primary_cat = provider.provider_categories.find(&:primary?) %>
          <% avg_rating = provider.reviews.any? ? provider.reviews.average(:rating).to_f.round(1) : nil %>
          <tr class="hover:bg-[#F9F9FF] transition-colors">
            <td class="px-4 lg:px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 lg:w-10 lg:h-10 rounded-full bg-[#0F766E]/10 flex items-center justify-center shrink-0">
                  <span class="text-sm font-bold text-[#0F766E]"><%= provider.name&.first&.upcase %></span>
                </div>
                <div>
                  <p class="font-bold text-[#111C2D] text-sm"><%= provider.name %></p>
                  <% if primary_cat %>
                    <span class="text-xs text-[#0F766E] bg-[#0F766E]/10 px-2 py-0.5 rounded-full font-medium"><%= primary_cat.name %></span>
                  <% end %>
                </div>
              </div>
            </td>
            <td class="px-4 lg:px-6 py-4 text-sm text-slate-600 hidden md:table-cell"><%= provider.city %></td>
            <td class="px-4 lg:px-6 py-4">
              <% if provider.active? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800">Activo</span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">Inactivo</span>
              <% end %>
            </td>
            <td class="px-4 lg:px-6 py-4 text-sm text-slate-500 hidden lg:table-cell">
              <%= provider.created_at&.strftime("%d %b %Y") %>
            </td>
            <td class="px-4 lg:px-6 py-4 text-sm hidden lg:table-cell">
              <% if avg_rating %>
                <span class="text-amber-500">⭐</span> <%= avg_rating %> (<%= provider.reviews.size %>)
              <% else %>
                <span class="text-slate-400">Sin reseñas</span>
              <% end %>
            </td>
            <td class="px-4 lg:px-6 py-4 text-right">
              <%= link_to admin_provider_path(provider),
                    class: "inline-flex items-center px-3 py-1.5 text-xs font-semibold text-[#0F766E] border border-[#0F766E]/30 rounded-lg hover:bg-[#0F766E]/5 transition-all" do %>
                Ver
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @providers.empty? %>
    <div class="text-center py-12">
      <span class="material-symbols-outlined text-4xl text-slate-300 mb-2">person_off</span>
      <p class="text-sm text-slate-400">No se encontraron proveedores</p>
    </div>
  <% end %>
</div>
