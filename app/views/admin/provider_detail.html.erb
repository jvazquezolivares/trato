<%# Admin Provider Detail — two-column layout with info card + activity %>
<% content_for(:page_title, @provider.name) %>

<div class="mb-4">
  <%= link_to admin_providers_path, class: "text-sm text-slate-500 hover:text-[#0F766E] transition-colors flex items-center gap-1" do %>
    <span class="material-symbols-outlined text-sm">arrow_back</span> Volver a proveedores
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
  <%# Left column — Provider info card %>
  <div class="lg:col-span-1">
    <div class="bg-white rounded-xl p-6 shadow-[0_32px_64px_-15px_rgba(17,28,45,0.06)]">
      <%# Profile header %>
      <div class="flex flex-col items-center text-center mb-6">
        <div class="w-20 h-20 rounded-full bg-[#0F766E]/10 flex items-center justify-center mb-3">
          <span class="text-2xl font-bold text-[#0F766E]"><%= @provider.name&.first&.upcase %></span>
        </div>
        <h2 class="text-lg font-extrabold text-[#111C2D] font-['Plus_Jakarta_Sans']"><%= @provider.name %></h2>
        <div class="flex flex-wrap gap-1.5 justify-center mt-2">
          <% @provider.provider_categories.each do |cat| %>
            <span class="text-xs px-2.5 py-0.5 rounded-full font-medium
                         <%= cat.primary? ? 'bg-[#0F766E] text-white' : 'bg-[#0F766E]/10 text-[#0F766E]' %>">
              <%= cat.name %>
            </span>
          <% end %>
        </div>
        <div class="mt-3">
          <% if @provider.active? %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-800">● Activo</span>
          <% else %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">● Inactivo</span>
          <% end %>
        </div>
      </div>

      <hr class="border-slate-100 mb-4">

      <%# Contact info %>
      <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Información de contacto</h3>
      <div class="space-y-3 text-sm mb-6">
        <div class="flex justify-between">
          <span class="text-slate-500">Teléfono</span>
          <span class="font-medium text-[#111C2D]"><%= @provider.phone %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-500">Short UUID</span>
          <span class="font-mono text-xs bg-slate-100 px-2 py-0.5 rounded text-slate-600"><%= @provider.short_uuid %></span>
        </div>
        <div class="flex justify-between items-start">
          <span class="text-slate-500">Link asistente</span>
          <span class="font-medium text-[#0F766E] text-xs text-right break-all"><%= @provider.assistant_whatsapp_link %></span>
        </div>
        <% if @provider.email.present? %>
          <div class="flex justify-between">
            <span class="text-slate-500">Email</span>
            <span class="font-medium text-[#111C2D]"><%= @provider.email %></span>
          </div>
        <% end %>
        <div class="flex justify-between">
          <span class="text-slate-500">Ciudad</span>
          <span class="font-medium text-[#111C2D]"><%= @provider.city %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-500">Registrado</span>
          <span class="font-medium text-[#111C2D]"><%= @provider.created_at&.strftime("%d %b %Y") %></span>
        </div>
      </div>

      <hr class="border-slate-100 mb-4">

      <%# Financial summary %>
      <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Finanzas este mes</h3>
      <div class="space-y-3 text-sm mb-6">
        <div class="flex justify-between">
          <span class="text-slate-500">Cobrado</span>
          <span class="font-bold text-green-600"><%= format_mxn(@financial[:income]) %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-500">Pendiente</span>
          <span class="font-bold text-amber-600"><%= format_mxn(@financial[:pending]) %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-500">Gastos</span>
          <span class="font-bold text-red-500"><%= format_mxn(@financial[:expenses]) %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-500">Trabajos</span>
          <span class="font-bold text-[#111C2D]"><%= @financial[:jobs_count] %></span>
        </div>
      </div>

      <%# Action buttons %>
      <div class="space-y-2">
        <% if @provider.slug.present? %>
          <%= link_to provider_profile_path(category_city: @provider.slug.split("/").first, slug: @provider.slug.split("/").last),
                target: "_blank",
                class: "w-full flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-semibold text-[#0F766E] border border-[#0F766E]/30 rounded-xl hover:bg-[#0F766E]/5 transition-all" do %>
            <span class="material-symbols-outlined text-sm">open_in_new</span> Ver perfil público
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Right column — Activity %>
  <div class="lg:col-span-2 space-y-6">
    <%# Recent conversations %>
    <div class="bg-white rounded-xl p-6 shadow-[0_32px_64px_-15px_rgba(17,28,45,0.06)]">
      <h3 class="text-lg font-extrabold text-[#111C2D] mb-4 font-['Plus_Jakarta_Sans']">Conversaciones recientes</h3>

      <% if @recent_conversations.any? %>
        <div class="space-y-3">
          <% @recent_conversations.each do |conv| %>
            <div class="flex items-center justify-between p-3 rounded-lg hover:bg-[#F9F9FF] transition-colors">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-medium text-[#111C2D]"><%= mask_phone(conv.phone) %></span>
                  <%= stage_badge(conv.stage) %>
                </div>
                <p class="text-xs text-slate-500 truncate">
                  <%= conv.messages.last&.body&.truncate(60) || "Sin mensajes" %>
                </p>
              </div>
              <div class="flex items-center gap-3 ml-3">
                <span class="text-xs text-slate-400 whitespace-nowrap"><%= time_ago_spanish(conv.last_message_at) %></span>
                <%= link_to admin_conversation_path(conv), class: "text-[#0F766E] text-xs font-semibold hover:underline" do %>
                  Ver
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-400 text-center py-6">Sin conversaciones recientes</p>
      <% end %>
    </div>

    <%# Recent jobs %>
    <div class="bg-white rounded-xl p-6 shadow-[0_32px_64px_-15px_rgba(17,28,45,0.06)]">
      <h3 class="text-lg font-extrabold text-[#111C2D] mb-4 font-['Plus_Jakarta_Sans']">Últimos trabajos</h3>

      <% if @recent_jobs.any? %>
        <div class="space-y-3">
          <% @recent_jobs.each do |job| %>
            <div class="flex items-center justify-between p-3 rounded-lg hover:bg-[#F9F9FF] transition-colors">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-[#111C2D]">
                  <%= job.client&.name || "Cliente" %> — <%= job.description&.truncate(40) %>
                </p>
                <p class="text-xs text-slate-500"><%= job.service_date&.strftime("%d %b %Y") %></p>
              </div>
              <div class="flex items-center gap-3 ml-3">
                <span class="text-sm font-bold text-[#111C2D]"><%= format_mxn(job.amount) %></span>
                <%= job_status_badge(job.status) %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-400 text-center py-6">Sin trabajos registrados</p>
      <% end %>
    </div>
  </div>
</div>
