<% content_for(:title) { "#{@directory.category_display_name} en #{humanize_city(@directory.city)} | Trato" } %>
<% content_for(:meta_description) { "#{@directory.total_count} #{@directory.category_display_name.downcase} verificados en #{humanize_city(@directory.city)}. Encuentra al profesional de confianza que necesitas." } %>

<%# ===== TOP NAVIGATION (matches Stitch nav — no "Pedir Servicio" per STITCH_PROMPT_v2 correction #1) ===== %>
<nav class="fixed top-0 w-full z-50 bg-[#F9F9FF]/80 backdrop-blur-md">
  <div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
    <div class="flex items-center gap-8">
      <a href="/" class="text-2xl font-extrabold text-[#0F766E] font-[Plus_Jakarta_Sans]">Trato</a>
      <div class="hidden md:flex items-center bg-[#F0F3FF] px-4 py-2 rounded-full" style="box-shadow: inset 0 0 0 1px rgba(189,201,198,0.15);">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-[#6E7977] mr-2">
          <path fill-rule="evenodd" d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Z" clip-rule="evenodd" />
        </svg>
        <input type="text" placeholder="Buscar servicios..." class="bg-transparent border-none focus:ring-0 text-sm w-64 font-[Manrope] text-[#111C2D] placeholder-[#6E7977]">
      </div>
    </div>
    <div class="flex items-center gap-6">
      <a href="/#unete" class="hidden md:inline text-[#3E4947] hover:text-[#0F766E] text-sm font-semibold font-[Manrope] transition-colors">¿Eres técnico? Únete</a>
      <a href="/login" class="bg-[#0F766E] text-white px-6 py-2.5 rounded-lg font-bold text-sm hover:opacity-90 transition-transform active:scale-95">Iniciar sesión</a>
    </div>
  </div>
</nav>

<main class="pt-24 pb-20 px-6 max-w-7xl mx-auto">

  <%# ===== BREADCRUMBS & HEADER (from Stitch design) ===== %>
  <section class="mb-10">
    <nav class="flex items-center gap-2 text-sm text-[#6E7977] mb-4 font-[Manrope]" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#005C55] transition-colors">Trato</a>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
        <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
      </svg>
      <a href="#" class="hover:text-[#005C55] transition-colors"><%= humanize_city(@directory.city) %></a>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
        <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
      </svg>
      <span class="text-[#111C2D] font-semibold"><%= @directory.category_display_name %></span>
    </nav>

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-[Plus_Jakarta_Sans] text-[#111C2D] tracking-tight mb-2">
          <%= @directory.category_display_name %> en <%= humanize_city(@directory.city) %>
        </h1>
        <p class="text-lg text-[#6E7977] font-[Manrope]">
          <%= @directory.total_count %> <%= @directory.total_count == 1 ? "profesional verificado listo" : "profesionales verificados listos" %> para ayudarte hoy mismo.
        </p>
      </div>

      <%# Verified badge — desktop only (from Stitch) %>
      <div class="hidden lg:flex items-center gap-2 text-[#005C55] bg-[#9CF2E8]/30 px-4 py-2 rounded-xl shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.49 4.49 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm font-bold uppercase tracking-wider">Perfiles Verificados</span>
      </div>
    </div>
  </section>

  <%# ===== FILTER BAR (from Stitch — horizontal scrollable chips) ===== %>
  <section class="mb-12 overflow-x-auto pb-4 -mx-6 px-6">
    <div class="flex items-center gap-3 whitespace-nowrap">
      <a href="<%= directory_filter_path(@directory.category_slug.pluralize + "-en-" + @directory.city, nil) %>"
         class="<%= filter_chip_classes(params[:filter], nil) %>">
        Todos
      </a>
      <a href="<%= directory_filter_path(@directory.category_slug.pluralize + "-en-" + @directory.city, 'mejor-calificados') %>"
         class="<%= filter_chip_classes(params[:filter], 'mejor-calificados') %>">
        Mejor calificados
      </a>
      <a href="<%= directory_filter_path(@directory.category_slug.pluralize + "-en-" + @directory.city, 'con-fotos') %>"
         class="<%= filter_chip_classes(params[:filter], 'con-fotos') %>">
        Con fotos de trabajos
      </a>
      <a href="<%= directory_filter_path(@directory.category_slug.pluralize + "-en-" + @directory.city, 'precio-bajo') %>"
         class="<%= filter_chip_classes(params[:filter], 'precio-bajo') %>">
        Precio: Bajo a Alto
      </a>
    </div>
  </section>

  <%# ===== PROVIDER CARD GRID (from Stitch — 3 col desktop, 1 col mobile) ===== %>
  <% if @directory.providers.any? %>
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @directory.providers.each do |provider| %>
        <% work_photo = first_work_photo(provider) %>
        <% profile = profile_photo_for(provider) %>
        <% primary_cat = primary_category_for(provider) %>
        <% rating = average_rating_for(provider) %>
        <% reviews_count = review_count_for(provider) %>
        <% specs = specialties_for(provider) %>

        <a href="<%= provider_profile_path(category_city: provider.slug.split('/').first, slug: provider.slug.split('/').last) %>"
           class="group bg-white rounded-xl overflow-hidden hover:shadow-[0_32px_32px_rgba(17,28,45,0.06)] hover:-translate-y-1 transition-all duration-300 flex flex-col">

          <%# Work photo as main image (STITCH_PROMPT_v2 correction #2) %>
          <div class="relative h-56 overflow-hidden">
            <% if work_photo %>
              <img
                src="<%= work_photo.url %>"
                alt="Trabajo de <%= provider.name %>"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              >
            <% else %>
              <%# Elegant placeholder with category icon (STITCH_PROMPT_v2 correction #3) %>
              <div class="w-full h-full bg-[#F1F5F9] flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-16 h-16 text-[#BDC9C6]">
                  <path d="M11.47 3.841a.75.75 0 0 1 1.06 0l8.69 8.69a.75.75 0 1 0 1.06-1.061l-8.689-8.69a2.25 2.25 0 0 0-3.182 0l-8.69 8.69a.75.75 0 1 0 1.061 1.06l8.69-8.689Z" />
                  <path d="m12 5.432 8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 0 1-.75-.75v-4.5a.75.75 0 0 0-.75-.75h-3a.75.75 0 0 0-.75.75V21a.75.75 0 0 1-.75.75H5.625a1.875 1.875 0 0 1-1.875-1.875v-6.198a.75.75 0 0 1 .091-.086L12 5.432Z" />
                </svg>
              </div>
            <% end %>

            <%# Rating badge — top right (from Stitch) %>
            <% if reviews_count.positive? %>
              <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md px-3 py-1 rounded-full flex items-center gap-1.5 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-[#FEA619]">
                  <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
                </svg>
                <span class="text-xs font-bold text-[#111C2D]"><%= rating %> (<%= reviews_count %>)</span>
              </div>
            <% end %>

            <%# Circular profile photo — bottom left overlapping (STITCH_PROMPT_v2 correction #2) %>
            <div class="absolute -bottom-4 left-6 w-10 h-10 rounded-full border-2 border-white overflow-hidden shadow-md z-10 bg-white">
              <% if profile %>
                <img src="<%= profile.url %>" alt="<%= provider.name %>" class="w-full h-full object-cover">
              <% else %>
                <div class="w-full h-full bg-[#0F766E] flex items-center justify-center">
                  <span class="text-xs font-bold text-white font-[Plus_Jakarta_Sans]"><%= provider_initials(provider.name) %></span>
                </div>
              <% end %>
            </div>
          </div>

          <%# Card content %>
          <div class="p-6 pt-8 flex-1 flex flex-col">
            <%# Name + price row %>
            <div class="flex justify-between items-start mb-1">
              <h3 class="text-lg font-bold font-[Plus_Jakarta_Sans] text-[#111C2D] group-hover:text-[#005C55] transition-colors">
                <%= provider.name %>
              </h3>
              <% if provider.base_price.present? %>
                <span class="text-[#0F766E] font-extrabold text-lg shrink-0">
                  <%= provider.base_price %><span class="text-xs font-medium text-[#6E7977]">/visita</span>
                </span>
              <% end %>
            </div>

            <%# Category + city %>
            <p class="text-sm text-[#3E4947] mb-3 font-[Manrope]">
              <%= primary_cat&.name %> · <%= provider.city %>
            </p>

            <%# Bio excerpt %>
            <% if provider.bio.present? %>
              <p class="text-sm text-[#6E7977] line-clamp-2 mb-4 font-[Manrope] leading-relaxed"><%= provider.bio %></p>
            <% end %>

            <%# Specialty chips — visible on hover only on desktop (STITCH_PROMPT_v2 correction #4) %>
            <% if specs.any? %>
              <div class="hidden md:flex opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex-wrap gap-2 mb-4">
                <% specs.each do |specialty| %>
                  <span class="bg-[#005C55]/10 text-[#005C55] text-[10px] uppercase font-bold tracking-widest px-2 py-1 rounded">
                    <%= specialty %>
                  </span>
                <% end %>
              </div>
            <% end %>

            <%# Footer: verified badge + CTA button %>
            <div class="mt-auto pt-4 flex items-center justify-between" style="border-top: 1px solid rgba(189,201,198,0.15);">
              <span class="text-xs font-semibold text-[#005C55] flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                  <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
                </svg>
                Verificado
              </span>
              <span class="bg-[#FEA619] text-white px-4 py-2 rounded-lg font-bold text-sm hover:opacity-90 transition-transform active:scale-95">
                Contactar 💬
              </span>
            </div>
          </div>
        </a>
      <% end %>
    </section>

    <%# ===== PAGINATION (from Stitch) ===== %>
    <section class="mt-16 text-center">
      <% if @directory.total_pages > 1 %>
        <div class="flex items-center justify-center gap-2">
          <% if @directory.page > 1 %>
            <a href="<%= category_directory_path(category_city: @directory.category_slug.pluralize + '-en-' + @directory.city, page: @directory.page - 1, filter: params[:filter]) %>"
               class="inline-flex items-center gap-2 bg-[#F0F3FF] hover:bg-[#DEE8FF] text-[#111C2D] px-6 py-3 rounded-xl font-bold transition-all active:scale-95">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                <path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
              </svg>
              Anterior
            </a>
          <% end %>

          <% (1..@directory.total_pages).each do |page_num| %>
            <% if page_num == @directory.page %>
              <span class="w-10 h-10 flex items-center justify-center rounded-lg bg-[#005C55] text-white font-bold text-sm">
                <%= page_num %>
              </span>
            <% else %>
              <a href="<%= category_directory_path(category_city: @directory.category_slug.pluralize + '-en-' + @directory.city, page: page_num, filter: params[:filter]) %>"
                 class="w-10 h-10 flex items-center justify-center rounded-lg bg-[#F0F3FF] hover:bg-[#DEE8FF] text-[#111C2D] font-bold text-sm transition-all">
                <%= page_num %>
              </a>
            <% end %>
          <% end %>

          <% if @directory.page < @directory.total_pages %>
            <a href="<%= category_directory_path(category_city: @directory.category_slug.pluralize + '-en-' + @directory.city, page: @directory.page + 1, filter: params[:filter]) %>"
               class="inline-flex items-center gap-2 bg-[#F0F3FF] hover:bg-[#DEE8FF] text-[#111C2D] px-6 py-3 rounded-xl font-bold transition-all active:scale-95">
              Siguiente
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            </a>
          <% end %>
        </div>
      <% end %>

      <p class="mt-4 text-sm text-[#6E7977] font-[Manrope]">
        Mostrando <%= (@directory.page - 1) * DirectoryService::PER_PAGE + 1 %>–<%= [(@directory.page) * DirectoryService::PER_PAGE, @directory.total_count].min %> de <%= @directory.total_count %> resultados
      </p>
    </section>

  <% else %>
    <%# ===== EMPTY STATE ===== %>
    <section class="text-center py-20">
      <div class="text-6xl mb-6">🔍</div>
      <h2 class="text-2xl font-extrabold font-[Plus_Jakarta_Sans] text-[#111C2D] mb-3">
        No encontramos técnicos para esa búsqueda
      </h2>
      <p class="text-[#6E7977] font-[Manrope] mb-8">
        Intenta con otros términos o busca en otra ciudad
      </p>
      <a href="/" class="inline-flex items-center gap-2 bg-[#0F766E] text-white px-8 py-3 rounded-xl font-bold transition-all hover:opacity-90 active:scale-95">
        Ver todos los técnicos
      </a>
    </section>
  <% end %>
</main>

<%# ===== SEO FOOTER (from Stitch design) ===== %>
<footer class="bg-[#F8FAFC] w-full mt-20">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-8 px-8 py-12 max-w-7xl mx-auto text-sm font-[Manrope]">
    <div>
      <h4 class="text-[#0F766E] font-bold mb-4 uppercase tracking-wider text-xs">Categorías Populares</h4>
      <ul class="space-y-2">
        <li><a href="/p/fontaneros-en-veracruz" class="text-[#6E7977] hover:text-[#005C55] transition-colors">Fontaneros</a></li>
        <li><a href="/p/electricistas-en-veracruz" class="text-[#6E7977] hover:text-[#005C55] transition-colors">Electricistas</a></li>
        <li><a href="/p/carpinteros-en-veracruz" class="text-[#6E7977] hover:text-[#005C55] transition-colors">Carpinteros</a></li>
        <li><a href="/p/albaniles-en-veracruz" class="text-[#6E7977] hover:text-[#005C55] transition-colors">Albañiles</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-[#0F766E] font-bold mb-4 uppercase tracking-wider text-xs">Ciudades</h4>
      <ul class="space-y-2">
        <li><a href="#" class="text-[#6E7977] hover:text-[#005C55] transition-colors">Veracruz</a></li>
        <li><a href="#" class="text-[#6E7977] hover:text-[#005C55] transition-colors">Boca del Río</a></li>
        <li><a href="#" class="text-[#6E7977] hover:text-[#005C55] transition-colors">CDMX</a></li>
        <li><a href="#" class="text-[#6E7977] hover:text-[#005C55] transition-colors">Puebla</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-[#0F766E] font-bold mb-4 uppercase tracking-wider text-xs">Ayuda</h4>
      <ul class="space-y-2">
        <li><a href="#" class="text-[#6E7977] hover:text-[#005C55] transition-colors">Preguntas Frecuentes</a></li>
        <li><a href="#" class="text-[#6E7977] hover:text-[#005C55] transition-colors">Cómo funciona</a></li>
        <li><a href="#" class="text-[#6E7977] hover:text-[#005C55] transition-colors">Soporte</a></li>
      </ul>
    </div>
    <div>
      <div class="text-xl font-bold text-[#0F766E] mb-4 font-[Plus_Jakarta_Sans]">Trato</div>
      <p class="text-[#6E7977] mb-6 leading-relaxed">Conectamos a los mejores profesionales con los hogares que más los necesitan.</p>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-8 py-8 flex flex-col md:flex-row justify-between items-center gap-4" style="border-top: 1px solid rgba(189,201,198,0.2);">
    <p class="text-[#6E7977] text-xs">© <%= Date.current.year %> Trato. Tu hogar, en buenas manos.</p>
    <div class="flex gap-6">
      <a href="#" class="text-[#6E7977] hover:text-[#005C55] text-xs transition-colors">Términos</a>
      <a href="#" class="text-[#6E7977] hover:text-[#005C55] text-xs transition-colors">Privacidad</a>
    </div>
  </div>
</footer>
