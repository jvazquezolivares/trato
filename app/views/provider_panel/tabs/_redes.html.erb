<%# Tab 3: Social media — connect Facebook, Instagram auto-linked %>
<%# Locals: panel (ProviderPanelService) %>
<%# Design reference: Stitch "Trato - Panel (Redes Sociales)" %>
<% provider = panel.provider %>
<% social = panel.social_status %>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8 items-start">
  <%# Left Column: Facebook Integration %>
  <div class="lg:col-span-7 bg-white rounded-2xl p-6 md:p-10 shadow-sm border border-gray-100 transition-all hover:shadow-md">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-14 w-14 rounded-2xl bg-[#1877F2]/10 flex items-center justify-center text-[#1877F2]">
        <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-[#1E293B]">Página de Facebook</h2>
        <p class="text-[#6E7977] text-sm mt-1">Comparte tus reseñas y trabajos realizados de forma automática.</p>
      </div>
    </div>

    <div class="space-y-6">
      <% if social[:facebook_connected] %>
        <%# Connected state %>
        <div class="bg-green-50 rounded-2xl p-6 border border-green-200">
          <div class="flex items-center gap-3 mb-3">
            <span class="material-symbols-outlined text-green-600" style="font-variation-settings: 'FILL' 1;">check_circle</span>
            <p class="text-green-700 font-bold text-sm">Facebook conectado ✓</p>
          </div>
          <% if social[:facebook_page_url].present? %>
            <p class="text-[#6E7977] text-sm mb-4"><%= social[:facebook_page_url] %></p>
          <% end %>
          <a href="#" class="text-[#94A3B8] text-xs hover:text-red-500 transition-colors">
            Desconectar
          </a>
        </div>
      <% else %>
        <%# Not connected state %>
        <div>
          <label class="block text-xs font-bold text-[#6E7977] uppercase tracking-widest mb-3 ml-1">URL de tu Página</label>
          <div class="relative">
            <input type="text"
                   class="w-full bg-[#F0F3FF] border-none rounded-2xl py-4 px-6 focus:ring-2 focus:ring-[#0F766E]/20 text-[#1E293B] transition-all placeholder:text-[#94A3B8]"
                   placeholder="https://facebook.com/tu-negocio"
                   disabled>
            <div class="absolute inset-y-0 right-4 flex items-center">
              <span class="material-symbols-outlined text-[#BDC9C6]">link</span>
            </div>
          </div>
        </div>

        <div class="bg-[#F0F3FF]/50 rounded-2xl p-6 flex gap-4 items-start border border-gray-100">
          <span class="material-symbols-outlined text-[#0F766E] mt-0.5">auto_awesome</span>
          <p class="text-sm text-[#6E7977] leading-relaxed">
            Al conectar tu cuenta, podremos publicar automáticamente tus mejores fotos de trabajos finalizados y las reseñas 5 estrellas de tus clientes directamente en tu muro.
            <span class="font-bold text-[#1E293B] block mt-1">¡Aumenta tu confianza digital sin esfuerzo!</span>
          </p>
        </div>

        <a href="/connect/facebook"
           class="w-full md:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#1877F2] text-white font-bold rounded-2xl hover:opacity-90 shadow-lg shadow-[#1877F2]/20 transition-all active:scale-[0.98]">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          Conectar Facebook
        </a>
      <% end %>
    </div>
  </div>

  <%# Right Column: Instagram Context %>
  <div class="lg:col-span-5 space-y-6">
    <div class="bg-[#DEE8FF] rounded-2xl p-6 md:p-8 border border-gray-100">
      <div class="flex items-center gap-4 mb-6">
        <div class="h-12 w-12 rounded-xl bg-gradient-to-tr from-[#f9ce34] via-[#ee2a7b] to-[#6228d7] flex items-center justify-center text-white">
          <svg class="w-7 h-7 fill-current" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold text-[#1E293B]">Instagram</h2>
      </div>

      <div class="space-y-4">
        <div class="bg-white p-6 rounded-2xl border-l-4 border-[#0F766E]">
          <p class="text-sm text-[#6E7977] font-medium leading-relaxed">
            Para conectar tu cuenta de Instagram, ésta debe ser una <span class="text-[#1E293B] font-bold">Cuenta Profesional</span> y estar vinculada a tu Página de Facebook.
          </p>
        </div>

        <p class="text-sm text-[#6E7977] px-2 italic">
          "Vincula tu cuenta de Instagram a tu Página de Facebook desde la configuración de Meta para activar esta función."
        </p>

        <div class="pt-4 flex items-center gap-2">
          <% if social[:instagram_linked] %>
            <div class="h-2 w-2 rounded-full bg-green-500"></div>
            <span class="text-xs font-bold uppercase tracking-widest text-green-600">Instagram activo</span>
          <% else %>
            <div class="h-2 w-2 rounded-full bg-[#94A3B8]"></div>
            <span class="text-xs font-bold uppercase tracking-widest text-[#6E7977]">Estado: Desconectado</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
