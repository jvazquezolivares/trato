<%# Metric card for the provider panel dashboard %>
<%# Locals: icon (String), value (String/Number), label (String), color (String hex), filled_icon (Boolean, optional) %>
<div class="bg-white p-4 md:p-6 rounded-xl shadow-sm flex flex-col gap-1 border border-gray-100">
  <span class="material-symbols-outlined text-xl mb-1"
        style="color: <%= color %>;<%= ' font-variation-settings: "FILL" 1;' if local_assigns[:filled_icon] %>">
    <%= icon %>
  </span>
  <span class="text-xl md:text-2xl font-bold text-[#1E293B]"><%= value %></span>
  <span class="text-[#64748B] text-xs md:text-sm font-medium"><%= label %></span>
</div>
